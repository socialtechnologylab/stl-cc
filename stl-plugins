#!/bin/bash
# STL Team Plugin Manager
# Manage Claude Code plugins for the team

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Find script directory (works even when called via symlink)
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")" && pwd)"
PLUGINS_FILE="$SCRIPT_DIR/plugins.txt"

# Check if claude CLI exists
CLAUDE_BIN=$(command -v claude 2>/dev/null || echo "/opt/homebrew/bin/claude")
if [[ ! -x "$CLAUDE_BIN" ]]; then
    echo -e "${RED}Error: claude CLI not found${NC}"
    exit 1
fi

# Parse plugins.txt, skip comments and empty lines
get_plugins() {
    grep -v '^#' "$PLUGINS_FILE" | grep -v '^[[:space:]]*$'
}

cmd_install() {
    echo -e "${BLUE}Installing STL plugins...${NC}"

    while IFS= read -r plugin || [[ -n "$plugin" ]]; do
        echo -e "${YELLOW}Installing:${NC} $plugin"
        "$CLAUDE_BIN" plugin install "$plugin" 2>&1 || echo -e "${RED}  Failed to install $plugin${NC}"
    done < <(get_plugins)

    echo -e "${GREEN}Done!${NC}"
}

cmd_update() {
    echo -e "${BLUE}Updating STL plugins...${NC}"

    # First update marketplaces
    echo -e "${YELLOW}Updating marketplaces...${NC}"
    "$CLAUDE_BIN" plugin marketplace update 2>&1 || true

    while IFS= read -r plugin || [[ -n "$plugin" ]]; do
        echo -e "${YELLOW}Updating:${NC} $plugin"
        "$CLAUDE_BIN" plugin update "$plugin" 2>&1 || echo -e "${RED}  Failed to update $plugin${NC}"
    done < <(get_plugins)

    echo -e "${GREEN}Done! Restart Claude Code to apply updates.${NC}"
}

cmd_delete() {
    echo -e "${BLUE}Removing STL plugins...${NC}"

    while IFS= read -r plugin || [[ -n "$plugin" ]]; do
        echo -e "${YELLOW}Removing:${NC} $plugin"
        "$CLAUDE_BIN" plugin uninstall "$plugin" 2>&1 || echo -e "${RED}  Failed to remove $plugin${NC}"
    done < <(get_plugins)

    echo -e "${GREEN}Done!${NC}"
}

cmd_list() {
    echo -e "${BLUE}STL Team Plugins:${NC}"
    echo ""
    get_plugins | while IFS= read -r plugin; do
        echo "  - $plugin"
    done
    echo ""
    echo -e "${YELLOW}File:${NC} $PLUGINS_FILE"
}

cmd_add() {
    local plugin="$1"
    if [[ -z "$plugin" ]]; then
        echo -e "${RED}Usage: stl-plugins add <plugin-name>${NC}"
        exit 1
    fi

    # Check if already in list
    if grep -q "^$plugin$" "$PLUGINS_FILE" 2>/dev/null; then
        echo -e "${YELLOW}Plugin already in list:${NC} $plugin"
    else
        echo "$plugin" >> "$PLUGINS_FILE"
        echo -e "${GREEN}Added to plugins.txt:${NC} $plugin"
    fi

    # Install it
    echo -e "${YELLOW}Installing:${NC} $plugin"
    "$CLAUDE_BIN" plugin install "$plugin"
    echo -e "${GREEN}Done!${NC}"
}

cmd_help() {
    echo "STL Team Plugin Manager"
    echo ""
    echo "Usage: stl-plugins <command> [args]"
    echo ""
    echo "Commands:"
    echo "  install     Install all plugins from plugins.txt"
    echo "  update      Update all plugins and marketplaces"
    echo "  delete      Remove all STL plugins"
    echo "  list        Show plugins in plugins.txt"
    echo "  add <name>  Add a plugin to plugins.txt and install it"
    echo "  help        Show this help"
    echo ""
    echo "Examples:"
    echo "  stl-plugins install"
    echo "  stl-plugins add context7@claude-plugins-official"
}

# Main
case "${1:-help}" in
    install) cmd_install ;;
    update)  cmd_update ;;
    delete)  cmd_delete ;;
    list)    cmd_list ;;
    add)     cmd_add "$2" ;;
    help|--help|-h) cmd_help ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}"
        cmd_help
        exit 1
        ;;
esac
